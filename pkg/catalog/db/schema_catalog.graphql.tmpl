# --- Module Intro View ---

"Module operations overview (SQL view)"
type module_intro @view(
  name: "_schema_module_intro"
  sql: """
  SELECT m.name AS module, 'queries' AS type_type,
         qt.name AS type_name, qft.name AS field_name,
         qft.description AS field_description, qft.hugr_type, qft.catalog
  FROM {{ if .IsPostgres }}[_schema_modules]{{ else }}core._schema_modules{{ end }} AS m
      INNER JOIN {{ if .IsPostgres }}[_schema_types]{{ else }}core._schema_types{{ end }} AS qt ON m.query_root = qt.name
      INNER JOIN {{ if .IsPostgres }}[_schema_fields]{{ else }}core._schema_fields{{ end }} AS qft ON qt.name = qft.type_name
  UNION ALL
  SELECT m.name, 'mutation', qt.name, qft.name, qft.description, qft.hugr_type, qft.catalog
  FROM {{ if .IsPostgres }}[_schema_modules]{{ else }}core._schema_modules{{ end }} AS m
      INNER JOIN {{ if .IsPostgres }}[_schema_types]{{ else }}core._schema_types{{ end }} AS qt ON m.mutation_root = qt.name
      INNER JOIN {{ if .IsPostgres }}[_schema_fields]{{ else }}core._schema_fields{{ end }} AS qft ON qt.name = qft.type_name
  UNION ALL
  SELECT m.name, 'function', qt.name, qft.name, qft.description, qft.hugr_type, qft.catalog
  FROM {{ if .IsPostgres }}[_schema_modules]{{ else }}core._schema_modules{{ end }} AS m
      INNER JOIN {{ if .IsPostgres }}[_schema_types]{{ else }}core._schema_types{{ end }} AS qt ON m.function_root = qt.name
      INNER JOIN {{ if .IsPostgres }}[_schema_fields]{{ else }}core._schema_fields{{ end }} AS qft ON qt.name = qft.type_name
  UNION ALL
  SELECT m.name, 'mut_function', qt.name, qft.name, qft.description, qft.hugr_type, qft.catalog
  FROM {{ if .IsPostgres }}[_schema_modules]{{ else }}core._schema_modules{{ end }} AS m
      INNER JOIN {{ if .IsPostgres }}[_schema_types]{{ else }}core._schema_types{{ end }} AS qt ON m.mut_function_root = qt.name
      INNER JOIN {{ if .IsPostgres }}[_schema_fields]{{ else }}core._schema_fields{{ end }} AS qft ON qt.name = qft.type_name
  """
) {
  module: String! @field_references(
    name: "mi_module_ref"
    field: "name"
    references_name: "modules"
    query: "module_info"
    description: "The module"
    references_query: "module_intro"
    references_description: "Module intro entries"
  )
  type_type: String!
  type_name: String!
  field_name: String!
  field_description: String!
  hugr_type: String!
  catalog: String @field_references(
    name: "mi_catalog_ref"
    field: "name"
    references_name: "catalogs"
    query: "catalog_info"
    description: "Owning catalog"
    references_query: "module_intro_in_catalog"
    references_description: "Module intro fields from this catalog"
  )
}

