# core.catalog Schema Views
# Mounted as module core.catalog — types accessed as core.catalog.catalogs, core.catalog.types, etc.
# Conditional: @embeddings directives included only when EmbeddingsEnabled=true

# --- Catalogs (data sources) ---

"Schema catalogs (data sources)"
type catalogs @view(name: "_schema_catalogs", sql: """
  FROM {{ if .IsPostgres }}[_schema_catalogs]{{ else }}core._schema_catalogs{{ end }} c
  LEFT JOIN {{ if .IsPostgres }}[data_sources]{{ else }}core.data_sources{{ end }} ds ON c.name = ds.name
""")
  {{ if .EmbeddingsEnabled }}@embeddings(model: "system", vector: "vec", distance: Cosine){{ end }} {
  name: String! @pk @sql(expression: "c.name")
  version: String! @sql(expression: "c.version")
  description: String! @sql(expression: "c.description")
  long_description: String! @sql(expression: "c.long_description")
  type: String @sql(expression: "ds.type")
  prefix: String @sql(expression: "COALESCE(ds.prefix, '')")
  as_module: Boolean @sql(expression: "COALESCE(ds.as_module, false)")
  read_only: Boolean @sql(expression: "COALESCE(ds.read_only, false)")
  disabled: Boolean! @sql(expression: "c.disabled")
  suspended: Boolean! @sql(expression: "c.suspended")
  is_summarized: Boolean! @sql(expression: "c.is_summarized")
  {{ if .EmbeddingsEnabled }}vec: Vector @dim(len: {{ .VectorSize }}) @sql(expression: "c.vec"){{ end }}
}

# --- Catalog Dependencies ---

"Catalog dependency tracking"
type catalog_dependencies @view(name: "_schema_catalog_dependencies", sql: "FROM core._schema_catalog_dependencies")
  @references(
    name: "catalog_dep_catalog"
    source_fields: ["catalog"]
    references_fields: ["name"]
    references_name: "catalogs"
    query: "catalog_info"
    description: "The dependent catalog"
    references_query: "dependencies"
    references_description: "Catalogs this catalog depends on"
  )
  @references(
    name: "catalog_dep_depends_on"
    source_fields: ["depends_on"]
    references_fields: ["name"]
    references_name: "catalogs"
    query: "depends_on_info"
    description: "The dependency catalog"
    references_query: "dependents"
    references_description: "Catalogs that depend on this catalog"
  ) {
  catalog: String! @pk
  depends_on: String! @pk
}

# --- Types ---

"Schema type definitions"
type types @view(name: "_schema_types", sql: "FROM core._schema_types")
  {{ if .EmbeddingsEnabled }}@embeddings(model: "system", vector: "vec", distance: Cosine){{ end }} {
  name: String! @pk
  kind: String!
  description: String!
  long_description: String!
  hugr_type: String!
  module: String! @field_references(
    name: "types_module_ref"
    field: "name"
    references_name: "modules"
    query: "module_info"
    description: "Module this type belongs to"
    references_query: "types_in_module"
    references_description: "Types in this module"
  )
  catalog: String @field_references(
    name: "types_catalog_ref"
    field: "name"
    references_name: "catalogs"
    query: "catalog_info"
    description: "Catalog this type belongs to"
    references_query: "types_in_catalog"
    references_description: "Types in this catalog"
  )
  is_summarized: Boolean!
  {{ if .EmbeddingsEnabled }}vec: Vector @dim(len: {{ .VectorSize }}){{ end }}
}

# --- Fields ---

"Schema field definitions"
type fields @view(name: "_schema_fields", sql: "FROM core._schema_fields")
  {{ if .EmbeddingsEnabled }}@embeddings(model: "system", vector: "vec", distance: Cosine){{ end }} {
  type_name: String! @pk @field_references(
    name: "fields_type_name_ref"
    field: "name"
    references_name: "types"
    query: "root_type"
    description: "The type this field belongs to"
    references_query: "fields"
    references_description: "Fields of this type"
  )
  name: String! @pk
  description: String!
  long_description: String!
  field_type: String!
  field_type_name: String! @field_references(
    name: "fields_type_ref"
    field: "name"
    references_name: "types"
    query: "type"
    description: "The GraphQL type of this field"
    references_query: "typed_fields"
    references_description: "Fields with this type"
  )
  hugr_type: String!
  catalog: String @field_references(
    name: "fields_catalog_ref"
    field: "name"
    references_name: "catalogs"
    query: "catalog_info"
    description: "Catalog this field belongs to"
    references_query: "fields_in_catalog"
    references_description: "Fields in this catalog"
  )
  dependency_catalog: String @field_references(
    name: "fields_dep_catalog_ref"
    field: "name"
    references_name: "catalogs"
    query: "dependency_catalog_info"
    description: "Extension source catalog"
    references_query: "extension_fields"
    references_description: "Extension fields from this catalog"
  )
  is_summarized: Boolean!
  ordinal: Int!
  {{ if .EmbeddingsEnabled }}vec: Vector @dim(len: {{ .VectorSize }}){{ end }}
}

# --- Arguments ---

"Schema field arguments"
type arguments @view(name: "_schema_arguments", sql: "FROM core._schema_arguments")
  @references(
    name: "args_field_ref"
    source_fields: ["type_name", "field_name"]
    references_fields: ["type_name", "name"]
    references_name: "fields"
    query: "field"
    description: "The field this argument belongs to"
    references_query: "arguments"
    references_description: "Arguments of this field"
  ) {
  type_name: String! @pk
  field_name: String! @pk
  name: String! @pk
  description: String!
  arg_type: String!
  arg_type_name: String! @field_references(
    name: "args_type_ref"
    field: "name"
    references_name: "types"
    query: "argument_type"
    description: "The type of this argument"
    references_query: "argument_usages"
    references_description: "Arguments with this type"
  )
  is_list: Boolean!
  is_non_null: Boolean!
  default_value: String
}

