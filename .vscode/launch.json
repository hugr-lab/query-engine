    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch server with memory db",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "env": {
                "CGO_CFLAGS":"-O1 -g"
            },
            "envFile": "${workspaceFolder}/.local/.memory.env",
            "program": "${workspaceFolder}/cmd/dev-server",
            "buildFlags": ["-tags", "duckdb_arrow"]
        },
        {
            "name": "Launch server with db",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "env": {
                "CGO_CFLAGS":"-O1 -g"
            },
            "envFile": "${workspaceFolder}/.local/.env",
            "program": "${workspaceFolder}/cmd/dev-server",
            "buildFlags": ["-tags=duckdb_arrow"]
        },
        {
            "name": "Launch server with db new compiler",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "env": {
                "CGO_CFLAGS":"-O1 -g",
                "USE_NEW_COMPILER":"true"
            },
            "envFile": "${workspaceFolder}/.local/.env",
            "program": "${workspaceFolder}/cmd/dev-server",
            "buildFlags": ["-tags=duckdb_arrow"]
        },
        {
            "name": "Launch server with auth and db",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "env": {
                "CGO_CFLAGS":"-O1 -g"
            },
            "envFile": "${workspaceFolder}/.local/.auth.env",
            "program": "${workspaceFolder}/cmd/dev-server",
            "buildFlags": ["-tags=duckdb_arrow"]
        },
        {
            "name": "Launch server with pg core db and auth",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "env": {
                "CGO_CFLAGS":"-O1 -g"
            },
            "envFile": "${workspaceFolder}/.local/.pg.env",
            "program": "${workspaceFolder}/cmd/dev-server",
            "buildFlags": ["-tags=duckdb_arrow"]
        },
        {
            "name": "Launch Package",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${fileDirname}",
            "buildFlags": ["-tags=duckdb_arrow"]
        },
                {
            "name": "Launch air server multi",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "env": {
                "CGO_CFLAGS":"-O1 -g"
            },
            "program": "${workspaceFolder}/internal/airport_test_service",
            "args": [
                "--addr", ":50433",
                "--token", "test-token",
                "--multi",
            ],
            "buildFlags": ["-tags=duckdb_arrow"]
        },
    ]
}