    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch server with memory db",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "env": {
                "CGO_CFLAGS":"-O1 -g"
            },
            "envFile": "${workspaceFolder}/.local/.memory.env",
            "program": "${workspaceFolder}/cmd/dev-server",
            "buildFlags": ["-tags", "duckdb_arrow"]
        },
        {
            "name": "Launch server with db",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "env": {
                "CGO_CFLAGS":"-O1 -g"
            },
            "envFile": "${workspaceFolder}/.local/.env",
            "program": "${workspaceFolder}/cmd/dev-server",
            "buildFlags": ["-tags=duckdb_arrow"]
        },
        {
            "name": "Launch server bug",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "env": {
                "CGO_CFLAGS":"-O1 -g"
            },
            "envFile": "${workspaceFolder}/.local/.env.bug",
            "program": "${workspaceFolder}/cmd/dev-server",
            "buildFlags": ["-tags=duckdb_arrow"]
        },
        {
            "name": "Launch server with auth and db",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "env": {
                "CGO_CFLAGS":"-O1 -g"
            },
            "envFile": "${workspaceFolder}/.local/.auth.env",
            "program": "${workspaceFolder}/cmd/dev-server",
            "buildFlags": ["-tags=duckdb_arrow"]
        },
        {
            "name": "Launch server with pg core db and auth",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "env": {
                "CGO_CFLAGS":"-O1 -g"
            },
            "envFile": "${workspaceFolder}/.local/.pg.env",
            "program": "${workspaceFolder}/cmd/dev-server",
            "buildFlags": ["-tags=duckdb_arrow"]
        },
        {
            "name": "Launch Package",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${fileDirname}",
            "buildFlags": ["-tags=duckdb_arrow"]
        },
                {
            "name": "Launch air server multi",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "env": {
                "CGO_CFLAGS":"-O1 -g"
            },
            "program": "${workspaceFolder}/internal/airport_test_service",
            "args": [
                "--addr", ":50433",
                "--token", "test-token",
                "--multi",
            ],
            "buildFlags": ["-tags=duckdb_arrow"]
        },
        {
            "name": "hugr-tools: summarize (local LLM)",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "env": {
                "CGO_CFLAGS": "-O1 -g"
            },
            "program": "${workspaceFolder}/cmd/hugr-tools",
            "args": [
                "summarize",
                "--url", "http://localhost:15000/ipc",
                "--provider", "custom",
                "--model", "openai/gpt-oss-20b",
                "--base-url", "http://127.0.0.1:1234/v1",
                "--api-key", "lm-studio",
                "--max-connections", "2"
            ],
            "buildFlags": ["-tags=duckdb_arrow"]
        },
        {
            "name": "hugr-tools: summarize dev db (local LLM)",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "env": {
                "CGO_CFLAGS": "-O1 -g"
            },
            "program": "${workspaceFolder}/cmd/hugr-tools",
            "args": [
                "summarize",
                "--url", "http://localhost:15003/ipc",
                "--provider", "custom",
                "--model", "openai/gpt-oss-20b",
                "--base-url", "http://127.0.0.1:1234/v1",
                "--api-key", "lm-studio",
                "--llm-timeout", "5m",
                "--max-connections", "2"
            ],
            "buildFlags": ["-tags=duckdb_arrow"]
        },
        {
            "name": "hugr-tools: summarize dev server (secret local LLM)",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "env": {
                "CGO_CFLAGS": "-O1 -g"
            },
            "program": "${workspaceFolder}/cmd/hugr-tools",
            "args": [
                "summarize",
                "--url", "http://localhost:15004/ipc",
                "--secret", "secret-key",
                "--secret-header", "x-hugr-secret-key",
                "--provider", "custom",
                "--model", "openai/gpt-oss-20b",
                "--base-url", "http://127.0.0.1:1234/v1",
                "--api-key", "lm-studio",
                "--llm-timeout", "5m",
                "--max-connections", "2"
            ],
            "buildFlags": ["-tags=duckdb_arrow"]
        },
        {
            "name": "hugr-tools: reindex",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "env": {
                "CGO_CFLAGS": "-O1 -g"
            },
            "program": "${workspaceFolder}/cmd/hugr-tools",
            "args": [
                "reindex",
                "--url", "http://localhost:15000/ipc",
                "--batch-size", "50"
            ],
            "buildFlags": ["-tags=duckdb_arrow"]
        },
        {
            "name": "hugr-tools: schema-info",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "env": {
                "CGO_CFLAGS": "-O1 -g"
            },
            "program": "${workspaceFolder}/cmd/hugr-tools",
            "args": [
                "schema-info",
                "--url", "http://localhost:15000/ipc",
                "--format", "table"
            ],
            "buildFlags": ["-tags=duckdb_arrow"]
        },
    ]
}